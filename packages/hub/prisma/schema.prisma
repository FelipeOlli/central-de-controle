generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  planejamento
  em_andamento
  pausado
  concluido
}

enum IdeaStatus {
  rascunho
  ativa
  em_projeto
  concluida
  arquivada
}

enum IdeaPriority {
  baixa
  media
  alta
}

enum CommitmentStatus {
  pendente
  em_andamento
  cumprido
  atrasado
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  themes       Theme[]
  projects     Project[]
  ideas        Idea[]
  commitments  Commitment[]
}

model Theme {
  id        String      @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ideaLinks IdeaTheme[]

  @@unique([userId, name])
}

model Project {
  id          String       @id @default(cuid())
  userId      String
  name        String
  description String?
  status      ProjectStatus @default(planejamento)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ideas       Idea[]
  commitments Commitment[]
}

model Idea {
  id          String      @id @default(cuid())
  userId      String
  title       String
  description String?
  status      IdeaStatus  @default(rascunho)
  priority    IdeaPriority?
  projectId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  themes      IdeaTheme[]
}

model IdeaTheme {
  ideaId    String
  themeId   String
  createdAt DateTime @default(now())
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  theme     Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([ideaId, themeId])
}

model Commitment {
  id          String           @id @default(cuid())
  userId      String
  title       String
  description String?
  dueDate     DateTime
  status      CommitmentStatus @default(pendente)
  projectId   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
}
